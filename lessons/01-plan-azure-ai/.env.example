# --- Microsoft Foundry model bake-off (AI-103 Lesson 1) ---
# Copy this file to ".env" and fill in your values, or set these as real env vars.
# Auth is keyless: sign in first with `az login` (no API keys needed).

# Foundry project endpoint: Foundry portal -> your project -> Overview -> Endpoint
FOUNDRY_PROJECT_ENDPOINT=https://<your-resource>.services.ai.azure.com/api/projects/<your-project>

# Deployment NAMES from your project's "Deployed models" table (not the base model id)
FLAGSHIP_DEPLOYMENT=gpt-5.1
SLM_DEPLOYMENT=phi-4
