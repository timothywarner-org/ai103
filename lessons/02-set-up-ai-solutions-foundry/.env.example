# --- AI-103 Lesson 2 demo: m02_setup_demo.py ---
# Copy this file to ".env" and fill in your values (or set them as real env vars).
# Auth is keyless: run `az login` first. No API keys anywhere.

# --- DATA plane: your Foundry PROJECT (read + call the deployment) ---
# Foundry portal -> your project -> Overview -> Endpoint
FOUNDRY_PROJECT_ENDPOINT=https://<your-resource>.services.ai.azure.com/api/projects/<your-project>

# --- CONTROL plane: the Foundry ACCOUNT that hosts the deployment (create/configure/delete) ---
# These identify the Azure resource. Azure portal -> your Foundry (AI Services) resource -> Overview.
AZURE_SUBSCRIPTION_ID=<your-subscription-guid>
AZURE_RESOURCE_GROUP=<your-resource-group>
FOUNDRY_ACCOUNT_NAME=<your-foundry-account-name>

# --- What to deploy (LO2/LO3). Model NAME is the base model id, not a deployment name. ---
# gpt-5-nano is a cheap, current small model with quota in the course's eastus2 account.
# (Older ids like gpt-4o-mini can hit "model is deprecating" and refuse NEW deployments.)
DEPLOY_MODEL_NAME=gpt-5-nano
DEPLOY_MODEL_FORMAT=OpenAI
# The gpt-5 family REQUIRES an explicit version (there is no "service default" to fall back on),
# which is itself the LO3 version-pinning lesson. Confirm the current version for your region:
#   az cognitiveservices model list -l <region> --query "[?model.name=='gpt-5-nano'].model.version"
DEPLOY_MODEL_VERSION=2025-08-07

# --- Deployment shape + config. Defaults are the cheapest, safest teaching choice. ---
# The name the demo creates (and deletes). Avoid clashing with a real deployment.
DEPLOY_NAME=ai103-l2-demo
# LO2 -- the deployment option. GlobalStandard | ProvisionedManaged | GlobalBatch | Standard | DataZoneStandard
DEPLOY_SKU=GlobalStandard
# Capacity units (keep tiny for the demo). For PTU SKUs this is the number of PTUs.
DEPLOY_CAPACITY=1
# LO3 -- version pinning. NoAutoUpgrade | OnceCurrentVersionExpired | OnceNewDefaultVersionAvailable
DEPLOY_UPGRADE_OPTION=NoAutoUpgrade
# LO3 -- content-filter (responsible-AI) policy attached at the deployment.
DEPLOY_RAI_POLICY=Microsoft.DefaultV2
