# --- AI-103 Lesson 1 demos ---
# Copy this file to ".env" and fill in your values (or set them as real env vars).
# Auth is keyless: sign in first with `az login` (no API keys needed).

# Foundry project endpoint -- used by BOTH demos.
# Foundry portal -> your project -> Overview -> Endpoint
FOUNDRY_PROJECT_ENDPOINT=https://<your-resource>.services.ai.azure.com/api/projects/<your-project>

# --- m01_agent_demo.py (the main demo: all four LOs) ---
# Deployment NAME of the chat model that powers the agent (NOT the base model id).
# Foundry portal -> your project -> Models + endpoints -> the deployment's Name column.
FOUNDRY_MODEL=gpt-5.1

# --- model_bakeoff.py (LO1 spotlight: flagship vs small model) ---
# Deployment NAME of your flagship LLM to compare.
# Foundry portal -> your project -> Models + endpoints -> Name column.
FLAGSHIP_DEPLOYMENT=gpt-5.1
# Deployment NAME of your small model to compare.
# Foundry portal -> your project -> Models + endpoints -> Name column.
# NOTE: Phi-4 is a serverless (MaaS) model. It deploys only in regions that offer
# it (e.g. eastus, westus3) and NOT into an AIServices account in every region
# (eastus2 has no Phi-4). If your region lacks Phi-4, use a small OpenAI model
# such as gpt-5-nano instead -- the "small vs flagship" lesson still lands.
SLM_DEPLOYMENT=gpt-5-nano
